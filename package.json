{
	"name": "ifttt-imessage",
	"version": "1.0.0",
	"description": "IFTTT integration for iMessage using Advanced iMessage Kit",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"format": "bunx @biomejs/biome check . --write",
		"lint": "bunx @biomejs/biome check ."
	},
	"dependencies": {
		"@photon-ai/advanced-imessage-kit": "^1.14.3",
		"hono": "^4.7.0",
		"consola": "^3.4.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.3",
		"@biomejs/biome": "^2.3.3"
	}
}
